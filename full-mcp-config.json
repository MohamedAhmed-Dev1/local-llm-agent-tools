{
  "mcpServers": {
    "file-access": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "PUT THE PATH YOU WANT THE LLM TO ACCESS HERE"
      ]
    },
        
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "PUT YOUR API KEY HERE"
      }
    }
  }
}
